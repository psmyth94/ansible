#!/usr/bin/env bash

set -e

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
VAULT_PASSWORD_FILE="${VAULT_PASSWORD_FILE:-$HOME/.vault.password.txt}"
TARGET_DIR="${TARGET_DIR:-$HOME}"

if [ ! -f "$VAULT_PASSWORD_FILE" ]; then
  echo "Vault password file not found: $VAULT_PASSWORD_FILE"
  exit 1
fi

if [ ! -d "$DOTFILES_DIR" ]; then
  echo "Dotfiles directory not found: $DOTFILES_DIR"
  exit 1
fi

# find all vault-encrypted files in dotfiles, then re-encrypt from the live target
found=0
while IFS= read -r -d '' file; do
  if head -1 "$file" 2>/dev/null | grep -q '^\$ANSIBLE_VAULT;'; then
    # dotfiles mirrors home structure directly
    rel="${file#"$DOTFILES_DIR"/}"
    src="$TARGET_DIR/$rel"

    if [ ! -f "$src" ]; then
      echo "Skipping: $src not found"
      continue
    fi

    cp "$src" "$file"
    ansible-vault encrypt "$file" --vault-password-file="$VAULT_PASSWORD_FILE"
    echo "Encrypted: $src -> $file"
    found=$((found + 1))
  fi
done < <(find "$DOTFILES_DIR" -type f -not -path '*/.git/*' -print0)

if [ "$found" -eq 0 ]; then
  echo "No vault-encrypted files found in $DOTFILES_DIR"
else
  echo "Encrypted $found file(s)"
fi
