#!/usr/bin/env bash

set -e

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
VAULT_PASSWORD_FILE="${VAULT_PASSWORD_FILE:-$HOME/.vault.password.txt}"
TARGET_DIR="${TARGET_DIR:-$HOME}"

if [ ! -f "$VAULT_PASSWORD_FILE" ]; then
  echo "Vault password file not found: $VAULT_PASSWORD_FILE"
  exit 1
fi

if [ ! -d "$DOTFILES_DIR" ]; then
  echo "Dotfiles directory not found: $DOTFILES_DIR"
  exit 1
fi

# find all vault-encrypted files, copy to their target location, then decrypt the copy
found=0
while IFS= read -r -d '' file; do
  if head -1 "$file" 2>/dev/null | grep -q '^\$ANSIBLE_VAULT;'; then
    # resolve stow target: strip the dotfiles dir and the first-level package directory
    rel="${file#"$DOTFILES_DIR"/}"
    # e.g. aws/.aws/credentials -> package=aws, inner=.aws/credentials
    inner="${rel#*/}"
    dest="$TARGET_DIR/$inner"

    mkdir -p "$(dirname "$dest")"
    rm -f "$dest"
    cp "$file" "$dest"
    ansible-vault decrypt "$dest" --vault-password-file="$VAULT_PASSWORD_FILE"
    chmod 600 "$dest"
    echo "Decrypted: $file -> $dest"
    found=$((found + 1))
  fi
done < <(find "$DOTFILES_DIR" -type f -not -path '*/.git/*' -print0)

if [ "$found" -eq 0 ]; then
  echo "No vault-encrypted files found in $DOTFILES_DIR"
else
  echo "Decrypted $found file(s)"
fi
